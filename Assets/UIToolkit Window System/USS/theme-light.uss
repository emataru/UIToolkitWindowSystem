:root {
    font-size: 10px;
}

/* =========================
   Window
   ========================= */

.window {
    background-color: rgb(250, 250, 250);
    color: rgb(32, 32, 32);

    border-left-color: rgba(0, 0, 0, 0.12);
    border-right-color: rgba(0, 0, 0, 0.12);
    border-top-color: rgba(0, 0, 0, 0.12);
    border-bottom-color: rgba(0, 0, 0, 0.12);

    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

.window-title {
    font-size: 10px;
}

.window-titlebar {
    background-color: rgb(245, 245, 245);

    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
}

.window-close-button {
    background-color: transparent;
    color: rgb(32, 32, 32);

    border-width: 0;

    border-top-left-radius: 0;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;

    font-size: 18px;
}

.window-close-button:hover {
    background-color: rgb(232, 17, 35);
    color: white;
}

.window-resize-handle {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 16px;
    height: 16px;
    background-color: transparent;
}

/* =========================
   Menu
   ========================= */

.menu-bar {
    background-color: rgb(245, 245, 245);
    border-bottom-color: rgba(0, 0, 0, 0.08);
}

.menu-panel {
    background-color: rgba(255, 255, 255, 0.98);
    border-color: rgba(0, 0, 0, 0.12);

    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

.menu-item {
    font-size: 10px;
    color: rgb(32, 32, 32);
    background-color: transparent;
}

.menu-item:hover {
    background-color: rgba(0, 120, 215, 0.10);

    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
}

.menu-item-disabled {
    color: rgba(32, 32, 32, 0.38);
}

.menu-bar-separator {
    background-color: rgba(0, 0, 0, 0.10);
}

.menu-item-separator {
    background-color: rgba(0, 0, 0, 0.08);
}

.menu-bar-icon {
    background-color: transparent;
}

.menu-bar-icon:hover {
    background-color: rgba(0, 120, 215, 0.10);

    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
}

/* =========================
   Buttons
   ========================= */

Button {
    background-color: rgb(243, 243, 243);
    color: rgb(32, 32, 32);

    border-left-color: rgba(0, 0, 0, 0.10);
    border-right-color: rgba(0, 0, 0, 0.10);
    border-top-color: rgba(0, 0, 0, 0.10);
    border-bottom-color: rgba(0, 0, 0, 0.10);

    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;

    height: 24px;
}

Button:hover {
    background-color: rgb(235, 235, 235);
}

Button:disabled {
    color: rgba(32, 32, 32, 0.38);
    background-color: rgb(248, 248, 248);
}

/* =========================
   Labels
   ========================= */

Label {
    color: rgb(32, 32, 32);
}

/* =========================
   TextField
   ========================= */

TextField {
    color: rgb(32, 32, 32);
    height: 24px;
    min-height: 24px;
}

TextField > .unity-label {
    color: rgb(32, 32, 32);
}

TextField > .unity-base-text-field__input,
TextField > .unity-text-input {
    background-color: rgb(255, 255, 255);
    color: rgb(32, 32, 32);

    padding-top: 0;
    padding-bottom: 0;
    padding-left: 8px;
    padding-right: 8px;

    -unity-text-align: middle-left;

    --unity-cursor-color: rgb(32, 32, 32);
    caret-color: rgb(32, 32, 32);

    border-left-color: rgba(0, 0, 0, 0.15);
    border-right-color: rgba(0, 0, 0, 0.15);
    border-top-color: rgba(0, 0, 0, 0.15);
    border-bottom-color: rgba(0, 0, 0, 0.15);

    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
}

TextField:focus-within > .unity-base-text-field__input,
TextField:focus-within > .unity-text-input {
    border-left-color: rgb(0, 120, 215);
    border-right-color: rgb(0, 120, 215);
    border-top-color: rgb(0, 120, 215);
    border-bottom-color: rgb(0, 120, 215);

    --unity-cursor-color: rgb(32, 32, 32);
    caret-color: rgb(32, 32, 32);
}

TextField::placeholder {
    color: rgba(32, 32, 32, 0.45);
}

/* =========================
   Toggle
   ========================= */

Toggle {
    color: rgb(32, 32, 32);
}

Toggle > .unity-label {
    color: rgb(32, 32, 32);
}

Toggle > .unity-checkmark {
    background-color: rgb(255, 255, 255);

    border-left-color: rgba(0, 0, 0, 0.15);
    border-right-color: rgba(0, 0, 0, 0.15);
    border-top-color: rgba(0, 0, 0, 0.15);
    border-bottom-color: rgba(0, 0, 0, 0.15);

    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
}

Toggle:checked > .unity-checkmark {
    background-color: rgb(0, 120, 215);
}

/* =========================
   ScrollView
   ========================= */

ScrollView {
    background-color: transparent;
}

ScrollView > .unity-scroll-view__content-container {
    background-color: transparent;
}

/* =========================
   PopupField / Dropdown
   ========================= */

.unity-base-popup-field {
    color: rgb(32, 32, 32);
}

.unity-base-popup-field > .unity-label {
    color: rgb(32, 32, 32);
}

.unity-base-popup-field__input {
    background-color: rgb(255, 255, 255);
    color: rgb(32, 32, 32);

    border-left-color: rgba(0, 0, 0, 0.15);
    border-right-color: rgba(0, 0, 0, 0.15);
    border-top-color: rgba(0, 0, 0, 0.15);
    border-bottom-color: rgba(0, 0, 0, 0.15);

    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
}

.unity-base-popup-field:focus-within > .unity-base-popup-field__input {
    border-left-color: rgb(0, 120, 215);
    border-right-color: rgb(0, 120, 215);
    border-top-color: rgb(0, 120, 215);
    border-bottom-color: rgb(0, 120, 215);
}